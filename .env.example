# Tmux Web Terminal Configuration
PORT=80
PASSWORD=""
JWT_SECRET=""
DEFAULT_SHELL=/bin/bash

# Multi-User System (Default: true)
# If PASSWORD or JWT_SECRET are empty or weak, they will be automatically generated and written back to .env on startup.
MULTI_USER_ENABLED=true

# HTTPS & SSL configuration (If using CDN SSL-termination, leave SSL_CERT_PATH and SSL_KEY_PATH empty)
# DOMAIN_NAME=outshine.cloud
# HTTPS_PORT=443
# SSL_CERT_PATH=/etc/letsencrypt/live/outshine.cloud/fullchain.pem
# SSL_KEY_PATH=/etc/letsencrypt/live/outshine.cloud/privkey.pem

# IM Bot (Telegram) Configuration
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather
# TELEGRAM_BOT_USERNAME=your_telegram_bot_username
# TELEGRAM_SECRET_TOKEN=your_telegram_webhook_secret_token
